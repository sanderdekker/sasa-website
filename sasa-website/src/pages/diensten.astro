---
import Layout from '../layouts/Layout.astro'
---
<Layout title="Diensten | SASA" currentPage="diensten">
<main class="pt-20">

  <!-- ═══════════════ HERO ═══════════════════════════════ -->
  <section class="relative overflow-hidden bg-mesh py-32 lg:py-44">
    <div class="max-w-7xl mx-auto px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary-container text-on-secondary-container mb-6 hero-anim hero-anim-1 px-el" data-depth="0.9">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">eco</span>
        <span class="text-xs font-bold tracking-wider uppercase font-label">Websites die resultaat leveren</span>
      </div>
      <h1 class="font-headline text-5xl md:text-7xl font-extrabold text-on-background tracking-tight leading-[1.05] mb-8 hero-anim hero-anim-2 px-el" data-depth="0.5">
        Websites die zorgen voor<br/>
        <span class="text-primary italic">online zichtbaarheid</span><br/>
        <span class="text-on-background">&amp; meer conversie</span>
      </h1>
      <p class="max-w-xl mx-auto text-on-surface-variant text-lg leading-relaxed hero-anim hero-anim-3 px-el" data-depth="0.3">
        Wij bouwen op maat gemaakte websites die jouw bedrijf beter vindbaar maken in Google <em>én</em> meer bezoekers omzetten in betalende klanten.
      </p>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-4 hero-anim hero-anim-4">
        <a href="/contact" class="btn-primary-gradient text-on-primary px-10 py-5 rounded-2xl font-bold text-lg btn-deep-shadow hover:translate-y-[-2px] active:scale-[0.98] transition-transform duration-200 inline-block focus-visible:ring-2 focus-visible:ring-[#7bd345] focus-visible:ring-offset-2">
          Gratis gesprek inplannen
        </a>
        <a href="#wat-wij-doen" class="inline-flex items-center gap-2 text-on-surface font-bold text-lg hover:text-primary transition-colors duration-200 group">
          Onze aanpak
          <span class="material-symbols-outlined transition-transform duration-200 group-hover:translate-y-1">arrow_downward</span>
        </a>
      </div>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-3 hero-anim hero-anim-5">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary" style="font-size:18px;font-variation-settings:'FILL' 1;">check_circle</span>
          <span class="text-sm font-semibold text-on-surface-variant">50+ websites gebouwd</span>
        </div>
        <span class="w-px h-4 bg-outline-variant/50 hidden sm:block"></span>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary" style="font-size:18px;font-variation-settings:'FILL' 1;">check_circle</span>
          <span class="text-sm font-semibold text-on-surface-variant">Gemiddeld 3× meer conversie</span>
        </div>
        <span class="w-px h-4 bg-outline-variant/50 hidden sm:block"></span>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary" style="font-size:18px;font-variation-settings:'FILL' 1;">check_circle</span>
          <span class="text-sm font-semibold text-on-surface-variant">Altijd 100% op maat</span>
        </div>
      </div>
    </div>
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary-fixed/25 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-secondary-fixed/20 rounded-full blur-3xl pointer-events-none"></div>
  </section>

  <!-- ═══════════════ WAT WIJ DOEN ════════════════════════ -->
  <section id="wat-wij-doen" class="py-28 px-8" style="background:rgba(248,250,251,0.85);position:relative;z-index:1;">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col lg:flex-row gap-16 items-center">
        <div class="lg:w-2/5 reveal">
          <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block font-label">Wat wij doen</span>
          <h2 class="text-4xl md:text-5xl font-extrabold font-headline tracking-tight text-on-surface leading-[1.05]">
            Websites die<br/><span class="text-primary italic">werken</span> — ook<br/>als jij slaapt
          </h2>
          <div class="mt-8">
            <a href="/contact" class="btn-primary-gradient text-on-primary px-8 py-4 rounded-xl font-bold inline-flex items-center gap-2 btn-deep-shadow hover:translate-y-[-2px] active:scale-[0.98] transition-transform duration-200 group">
              Start jouw project
              <span class="material-symbols-outlined transition-transform duration-200 group-hover:translate-x-1">arrow_forward</span>
            </a>
          </div>
        </div>
        <div class="lg:w-3/5 reveal" style="transition-delay:0.12s;">
          <p class="text-lg text-on-surface-variant leading-[1.8] font-body">
            Wij bouwen op maat gemaakte websites die jou helpen groeien. Met slimme <strong class="text-on-surface font-semibold">zoekmachineoptimalisatie</strong> zorgen we dat jouw doelgroep jou vindt in Google. Met een <strong class="text-on-surface font-semibold">conversiegericht design</strong> zetten we bezoekers om in betalende klanten.
          </p>
          <p class="mt-5 text-lg text-on-surface-variant leading-[1.8] font-body">
            Geen standaard templates — elk project is maatwerk, afgestemd op jouw merk, doelgroep en ambities. Van strategie en design tot livegang en doorlopende optimalisatie: wij staan op elke stap aan jouw zijde.
          </p>
          <div class="mt-8 grid grid-cols-3 gap-6 pt-8 border-t border-outline-variant/30">
            <div><div class="text-3xl font-extrabold font-headline text-on-surface tracking-tight">50+</div><div class="text-sm text-on-surface-variant font-body mt-1">Websites gebouwd</div></div>
            <div><div class="text-3xl font-extrabold font-headline text-on-surface tracking-tight">3×</div><div class="text-sm text-on-surface-variant font-body mt-1">Meer conversie</div></div>
            <div><div class="text-3xl font-extrabold font-headline text-on-surface tracking-tight">98%</div><div class="text-sm text-on-surface-variant font-body mt-1">Tevreden klanten</div></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ USPS ══════════════════════════════════ -->
  <section class="py-28 px-8 bg-white" style="position:relative;z-index:1;">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16 reveal">
        <span class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-4 block font-label">Waarom SASA</span>
        <h2 class="text-4xl md:text-5xl font-extrabold font-headline tracking-tight text-on-surface max-w-2xl mx-auto leading-tight">
          Alles wat jouw website nodig heeft om te scoren
        </h2>
      </div>
      <div id="usp-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="usp-card bg-surface-container-low rounded-[2rem] p-8 relative overflow-hidden group cursor-default" style="transition-delay:0s;">
          <div class="usp-icon-ring w-12 h-12 rounded-2xl flex items-center justify-center mb-6 shrink-0"><span class="material-symbols-outlined text-on-primary text-xl" style="font-variation-settings:'FILL' 1;">search</span></div>
          <h3 class="text-xl font-bold font-headline text-on-surface mb-3 tracking-tight">Gevonden in Google</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-body">SEO-geoptimaliseerd van de eerste regel code. Wij zorgen dat jouw doelgroep jou vindt — precies op het moment dat ze zoeken.</p>
          <div class="absolute bottom-0 right-0 w-24 h-24 bg-primary/5 rounded-full translate-x-6 translate-y-6 group-hover:bg-primary/10 transition-colors duration-300 pointer-events-none"></div>
        </div>
        <div class="usp-card bg-surface-container-low rounded-[2rem] p-8 relative overflow-hidden group cursor-default" style="transition-delay:0.1s;">
          <div class="usp-icon-ring w-12 h-12 rounded-2xl flex items-center justify-center mb-6 shrink-0"><span class="material-symbols-outlined text-on-primary text-xl" style="font-variation-settings:'FILL' 1;">trending_up</span></div>
          <h3 class="text-xl font-bold font-headline text-on-surface mb-3 tracking-tight">Meer conversie</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-body">Elke pixel werkt voor jou. Van CTA-plaatsing tot kleurgebruik — alles is bewust ontworpen om bezoekers te overtuigen actie te ondernemen.</p>
          <div class="absolute bottom-0 right-0 w-24 h-24 bg-primary/5 rounded-full translate-x-6 translate-y-6 group-hover:bg-primary/10 transition-colors duration-300 pointer-events-none"></div>
        </div>
        <div class="usp-card bg-surface-container-low rounded-[2rem] p-8 relative overflow-hidden group cursor-default" style="transition-delay:0.2s;">
          <div class="usp-icon-ring w-12 h-12 rounded-2xl flex items-center justify-center mb-6 shrink-0"><span class="material-symbols-outlined text-on-primary text-xl" style="font-variation-settings:'FILL' 1;">speed</span></div>
          <h3 class="text-xl font-bold font-headline text-on-surface mb-3 tracking-tight">Razendsnel &amp; stabiel</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-body">Meer dan 3 seconden laadtijd? Je verliest bezoekers én rankings. Onze sites scoren groen op Core Web Vitals — standaard.</p>
          <div class="absolute bottom-0 right-0 w-24 h-24 bg-primary/5 rounded-full translate-x-6 translate-y-6 group-hover:bg-primary/10 transition-colors duration-300 pointer-events-none"></div>
        </div>
        <div class="usp-card bg-surface-container-low rounded-[2rem] p-8 relative overflow-hidden group cursor-default" style="transition-delay:0.3s;">
          <div class="usp-icon-ring w-12 h-12 rounded-2xl flex items-center justify-center mb-6 shrink-0"><span class="material-symbols-outlined text-on-primary text-xl" style="font-variation-settings:'FILL' 1;">phone_iphone</span></div>
          <h3 class="text-xl font-bold font-headline text-on-surface mb-3 tracking-tight">100% Mobielvriendelijk</h3>
          <p class="text-on-surface-variant text-sm leading-relaxed font-body">Meer dan 70% van het webverkeer komt via mobiel. Wij bouwen altijd mobile-first — perfect op elk scherm en elk apparaat.</p>
          <div class="absolute bottom-0 right-0 w-24 h-24 bg-primary/5 rounded-full translate-x-6 translate-y-6 group-hover:bg-primary/10 transition-colors duration-300 pointer-events-none"></div>
        </div>
        <div class="usp-card md:col-span-2 lg:col-span-2 rounded-[2rem] p-8 relative overflow-hidden group" style="transition-delay:0.4s;background:linear-gradient(135deg,#d0f7aa 0%,#9fe870 50%,#7ad444 100%);box-shadow:0 12px 32px -8px rgba(159,232,112,0.5),0 4px 12px rgba(0,0,0,0.08);">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
            <div class="w-12 h-12 rounded-2xl bg-white/30 flex items-center justify-center shrink-0"><span class="material-symbols-outlined text-on-primary text-xl" style="font-variation-settings:'FILL' 1;">handshake</span></div>
            <div class="flex-1">
              <h3 class="text-xl font-bold font-headline text-on-primary mb-2 tracking-tight">Maatwerk — altijd</h3>
              <p class="text-on-primary/80 text-sm leading-relaxed font-body">Geen templates van de plank. Jouw website wordt van scratch gebouwd, uniek voor jouw merk, doelgroep en ambities. Jij bepaalt de koers — wij zorgen voor de uitvoering.</p>
            </div>
            <a href="/contact" class="shrink-0 bg-white text-on-primary px-6 py-3 rounded-xl font-bold text-sm hover:bg-white/90 active:scale-[0.98] transition-transform duration-200 whitespace-nowrap">Start jouw project</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CLIENT LOGOS ══════════════════════════ -->
  <section class="py-20 px-8 overflow-hidden" style="background:rgba(248,250,251,0.7);position:relative;z-index:1;">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12 reveal">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-on-surface-variant/50 font-label">Vertrouwd door groeiende ondernemers</p>
      </div>
      <div class="logos-grid flex flex-wrap justify-center items-center gap-8 md:gap-12">
        <div class="logo-card flex items-center gap-3 px-8 py-5 bg-white rounded-2xl border border-outline-variant/20 hover:border-primary/40 hover:shadow-md transition-all duration-200 cursor-default">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M14 3C14 3 5 8 5 16C5 20.4 9 24 14 24C19 24 23 20.4 23 16C23 8 14 3 14 3Z" fill="#9fe870" opacity="0.9"/><path d="M14 24V13M14 13C14 13 11 10 8 9M14 13C14 13 17 10 20 9" stroke="#4a7c30" stroke-width="1.5" stroke-linecap="round"/></svg>
          <span class="text-base font-black font-headline tracking-tight text-on-surface/60">Verdant</span>
        </div>
        <div class="logo-card flex items-center gap-3 px-8 py-5 bg-white rounded-2xl border border-outline-variant/20 hover:border-primary/40 hover:shadow-md transition-all duration-200 cursor-default">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="4" fill="#9fe870"/><ellipse cx="14" cy="14" rx="11" ry="5" stroke="#9fe870" stroke-width="1.5" opacity="0.7"/><ellipse cx="14" cy="14" rx="11" ry="5" stroke="#9fe870" stroke-width="1.5" opacity="0.4" transform="rotate(60 14 14)"/></svg>
          <span class="text-base font-black font-headline tracking-tight text-on-surface/60">Orbit</span>
        </div>
        <div class="logo-card flex items-center gap-3 px-8 py-5 bg-white rounded-2xl border border-outline-variant/20 hover:border-primary/40 hover:shadow-md transition-all duration-200 cursor-default">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><polygon points="14,2 17,11 26,11 19,17 21,26 14,20 7,26 9,17 2,11 11,11" fill="#9fe870" opacity="0.85"/><polygon points="14,6 16.5,12 23,12 18,16 20,22 14,18 8,22 10,16 5,12 11.5,12" fill="white" opacity="0.5"/></svg>
          <span class="text-base font-black font-headline tracking-tight text-on-surface/60">Lumina</span>
        </div>
        <div class="logo-card flex items-center gap-3 px-8 py-5 bg-white rounded-2xl border border-outline-variant/20 hover:border-primary/40 hover:shadow-md transition-all duration-200 cursor-default">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><path d="M4 14L12 6L20 14L12 22L4 14Z" fill="#9fe870" opacity="0.3"/><path d="M10 14L18 6L26 14L18 22L10 14Z" fill="#9fe870" opacity="0.7"/><path d="M16 14L20 10L24 14L20 18L16 14Z" fill="#7ad444"/></svg>
          <span class="text-base font-black font-headline tracking-tight text-on-surface/60">Kinetic</span>
        </div>
        <div class="logo-card flex items-center gap-3 px-8 py-5 bg-white rounded-2xl border border-outline-variant/20 hover:border-primary/40 hover:shadow-md transition-all duration-200 cursor-default">
          <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="3" fill="#9fe870"/><circle cx="5" cy="7" r="2.5" fill="#9fe870" opacity="0.7"/><circle cx="23" cy="7" r="2.5" fill="#9fe870" opacity="0.7"/><circle cx="5" cy="21" r="2.5" fill="#9fe870" opacity="0.7"/><circle cx="23" cy="21" r="2.5" fill="#9fe870" opacity="0.7"/><line x1="14" y1="14" x2="5" y2="7" stroke="#9fe870" stroke-width="1.2" opacity="0.5"/><line x1="14" y1="14" x2="23" y2="7" stroke="#9fe870" stroke-width="1.2" opacity="0.5"/><line x1="14" y1="14" x2="5" y2="21" stroke="#9fe870" stroke-width="1.2" opacity="0.5"/><line x1="14" y1="14" x2="23" y2="21" stroke="#9fe870" stroke-width="1.2" opacity="0.5"/></svg>
          <span class="text-base font-black font-headline tracking-tight text-on-surface/60">Nexus</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ WERKWIJZE ════════════════════════════ -->
  <section id="werkwijze" class="py-28 relative overflow-hidden" style="background:rgba(255,255,255,0.52);">
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="text-center mb-20 reveal">
        <span class="text-xs font-bold uppercase tracking-widest text-primary font-label mb-4 block">Werkwijze</span>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-on-background mb-4 tracking-tight px-el" data-depth="0.5">Onze aanpak in 3 stappen</h2>
        <p class="text-on-surface-variant max-w-xl mx-auto">Van eerste gesprek tot een groeiende digitale aanwezigheid — zo pakken we het aan.</p>
      </div>

      <!-- Desktop graph -->
      <div class="hidden md:block ww-wrap" style="position:relative;height:500px;">
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1000 420" preserveAspectRatio="xMidYMid meet" aria-hidden="true" style="overflow:visible;">
          <defs>
            <linearGradient id="wwArea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"   stop-color="#7ad444" stop-opacity="0.18"/>
              <stop offset="60%"  stop-color="#9fe870" stop-opacity="0.06"/>
              <stop offset="100%" stop-color="#9fe870" stop-opacity="0"/>
            </linearGradient>
            <linearGradient id="wwStroke" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%"   stop-color="#acf67c"/>
              <stop offset="50%"  stop-color="#7ad444"/>
              <stop offset="100%" stop-color="#5ab52a"/>
            </linearGradient>
            <filter id="wwGlow" x="-100%" y="-100%" width="300%" height="300%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="wwLineGlow" x="-5%" y="-100%" width="110%" height="300%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>
          <line x1="120" y1="390" x2="920" y2="390" stroke="rgba(0,0,0,0.08)" stroke-width="1"/>
          <line x1="120" y1="290" x2="920" y2="290" stroke="rgba(0,0,0,0.05)" stroke-width="1" stroke-dasharray="5,14"/>
          <line x1="120" y1="190" x2="920" y2="190" stroke="rgba(0,0,0,0.05)" stroke-width="1" stroke-dasharray="5,14"/>
          <line x1="120" y1="90"  x2="920" y2="90"  stroke="rgba(0,0,0,0.05)" stroke-width="1" stroke-dasharray="5,14"/>
          <text x="108" y="390" text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">0</text>
          <text x="108" y="290" text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">33</text>
          <text x="108" y="190" text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">66</text>
          <text x="108" y="90"  text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">100</text>
          <text transform="translate(62,240) rotate(-90)" text-anchor="middle" font-family="Manrope" font-size="9" font-weight="700" fill="rgba(65,73,58,0.28)" letter-spacing="3">GROEI %</text>
          <line x1="190" y1="350" x2="190" y2="390" stroke="rgba(122,212,68,0.35)" stroke-width="1" stroke-dasharray="4,7"/>
          <line x1="500" y1="220" x2="500" y2="390" stroke="rgba(122,212,68,0.25)" stroke-width="1" stroke-dasharray="4,7"/>
          <line x1="810" y1="75"  x2="810" y2="390" stroke="rgba(90,181,42,0.25)"  stroke-width="1" stroke-dasharray="4,7"/>
          <path class="ww-area" d="M 190 350 C 320 290 420 255 500 220 C 620 175 710 120 810 75 L 810 390 L 190 390 Z" fill="url(#wwArea)"/>
          <path class="ww-line" d="M 190 350 C 320 290 420 255 500 220 C 620 175 710 120 810 75" fill="none" stroke="url(#wwStroke)" stroke-width="2.5" stroke-linecap="round" filter="url(#wwLineGlow)"/>
          <circle class="ww-pulse-1" cx="190" cy="350" r="20" fill="none" stroke="#acf67c" stroke-width="1.5" opacity="0"/>
          <circle cx="190" cy="350" r="20" fill="none" stroke="rgba(172,246,124,0.22)" stroke-width="1"/>
          <circle cx="190" cy="350" r="12" fill="white" stroke="#acf67c" stroke-width="2.5" filter="url(#wwGlow)"/>
          <circle cx="190" cy="350" r="4.5" fill="#7ad444"/>
          <text x="190" y="410" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(65,73,58,0.50)" letter-spacing="1">PLAN</text>
          <circle class="ww-pulse-2" cx="500" cy="220" r="20" fill="none" stroke="#9fe870" stroke-width="1.5" opacity="0"/>
          <circle cx="500" cy="220" r="20" fill="none" stroke="rgba(159,232,112,0.22)" stroke-width="1"/>
          <circle cx="500" cy="220" r="12" fill="white" stroke="#9fe870" stroke-width="2.5" filter="url(#wwGlow)"/>
          <circle cx="500" cy="220" r="4.5" fill="#5ab52a"/>
          <text x="500" y="410" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(65,73,58,0.50)" letter-spacing="1">BOUWEN</text>
          <circle class="ww-pulse-3" cx="810" cy="75" r="20" fill="none" stroke="#7ad444" stroke-width="1.5" opacity="0"/>
          <circle cx="810" cy="75" r="20" fill="none" stroke="rgba(122,212,68,0.30)" stroke-width="1"/>
          <circle cx="810" cy="75" r="14" fill="white" stroke="#7ad444" stroke-width="3" filter="url(#wwGlow)"/>
          <circle cx="810" cy="75" r="5.5" fill="#5ab52a"/>
          <text x="810" y="48" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(90,181,42,0.70)" letter-spacing="2">↑ GROEI</text>
          <text x="810" y="410" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(65,73,58,0.50)" letter-spacing="1">GROEIEN</text>
        </svg>
