<script>
(function() {
  var targets = document.querySelectorAll('.ww-wrap, .ww-mob');
  if (!targets.length) return;
  var lp = document.querySelector('.ww-wrap .ww-line') as SVGPathElement | null;
  if (lp) {
    try {
      var len = Math.ceil(lp.getTotalLength()) + 20;
      lp.style.strokeDasharray = String(len);
      lp.style.strokeDashoffset = String(len);
    } catch(e) {}
  }
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('ww-go'); io.unobserve(e.target); }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
  targets.forEach(function(el) { io.observe(el); });
})();
</script>
