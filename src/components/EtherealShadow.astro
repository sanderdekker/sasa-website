---
// EtherealShadow.astro — Animated full-page green blob background
---
<div id="etheral-overlay" style="position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden;">
  <svg style="position:absolute;width:0;height:0;overflow:hidden;">
    <defs>
      <filter id="ef-a" x="-30%" y="-30%" width="160%" height="160%">
        <feTurbulence type="turbulence" baseFrequency="0.0014,0.0048" numOctaves="2" seed="3" result="undulation"/>
        <feColorMatrix id="eh-a" in="undulation" type="hueRotate" values="0" result="hued"/>
        <feColorMatrix in="hued" result="circ" type="matrix" values="4 0 0 0 1  4 0 0 0 1  4 0 0 0 1  1 0 0 0 0"/>
        <feDisplacementMap in="SourceGraphic" in2="circ" scale="120" result="dist"/>
        <feDisplacementMap in="dist" in2="undulation" scale="120"/>
      </filter>
      <filter id="ef-b" x="-30%" y="-30%" width="160%" height="160%">
        <feTurbulence type="turbulence" baseFrequency="0.0019,0.006" numOctaves="2" seed="11" result="undulation"/>
        <feColorMatrix id="eh-b" in="undulation" type="hueRotate" values="120" result="hued"/>
        <feColorMatrix in="hued" result="circ" type="matrix" values="4 0 0 0 1  4 0 0 0 1  4 0 0 0 1  1 0 0 0 0"/>
        <feDisplacementMap in="SourceGraphic" in2="circ" scale="95" result="dist"/>
        <feDisplacementMap in="dist" in2="undulation" scale="95"/>
      </filter>
      <filter id="ef-c" x="-30%" y="-30%" width="160%" height="160%">
        <feTurbulence type="turbulence" baseFrequency="0.001,0.0035" numOctaves="2" seed="17" result="undulation"/>
        <feColorMatrix id="eh-c" in="undulation" type="hueRotate" values="240" result="hued"/>
        <feColorMatrix in="hued" result="circ" type="matrix" values="4 0 0 0 1  4 0 0 0 1  4 0 0 0 1  1 0 0 0 0"/>
        <feDisplacementMap in="SourceGraphic" in2="circ" scale="110" result="dist"/>
        <feDisplacementMap in="dist" in2="undulation" scale="110"/>
      </filter>
    </defs>
  </svg>

  <!-- Blob A: top-left -->
  <div class="etheral-blob" style="position:absolute;width:75vw;height:75vh;top:-20%;left:-15%;filter:url(#ef-a) blur(12px);">
    <div style="background-color:rgba(159,232,112,0.28);mask-image:url('https://framerusercontent.com/images/ceBGguIpUU8luwByxuQz79t7To.png');mask-size:cover;mask-repeat:no-repeat;mask-position:center;width:100%;height:100%;"></div>
  </div>

  <!-- Blob B: top-right -->
  <div class="etheral-blob" style="position:absolute;width:65vw;height:65vh;top:-10%;right:-20%;filter:url(#ef-b) blur(14px);">
    <div style="background-color:rgba(172,246,124,0.22);mask-image:url('https://framerusercontent.com/images/ceBGguIpUU8luwByxuQz79t7To.png');mask-size:cover;mask-repeat:no-repeat;mask-position:center;width:100%;height:100%;"></div>
  </div>

  <!-- Blob C: bottom center -->
  <div class="etheral-blob" style="position:absolute;width:90vw;height:80vh;bottom:-25%;left:5%;filter:url(#ef-c) blur(16px);">
    <div style="background-color:rgba(145,217,99,0.25);mask-image:url('https://framerusercontent.com/images/ceBGguIpUU8luwByxuQz79t7To.png');mask-size:cover;mask-repeat:no-repeat;mask-position:center;width:100%;height:100%;"></div>
  </div>

  <!-- Noise grain -->
  <div style="position:absolute;inset:0;background-image:url('https://framerusercontent.com/images/g0QcWrxr87K0ufOxIUFBakwYA8.png');background-size:180px;background-repeat:repeat;opacity:0.04;"></div>
</div>

<script>
(function () {
  const ha = document.getElementById('eh-a');
  const hb = document.getElementById('eh-b');
  const hc = document.getElementById('eh-c');
  if (!ha) return;
  const DEG_PER_MS = 360 / (10 * 1000);
  let hue = 0, last = null;
  function tick(ts) {
    if (last !== null) {
      hue = (hue + DEG_PER_MS * (ts - last)) % 360;
      ha.setAttribute('values', String(hue));
      hb.setAttribute('values', String((hue + 120) % 360));
      hc.setAttribute('values', String((hue + 240) % 360));
    }
    last = ts;
    requestAnimationFrame(tick);
  }
  requestAnimationFrame(tick);
})();
</script>
