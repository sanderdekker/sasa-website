---
// Footer.astro
interface Props {
  variant?: 'default' | 'kennismaking';
}
const { variant = 'default' } = Astro.props;
---
<footer class="bg-[#1A2E26] w-full">
  <div class="max-w-7xl mx-auto px-8 py-12 flex flex-col md:flex-row justify-between items-start gap-8">
    <div class="space-y-2">
      <div class="text-xl font-bold text-white font-headline">SASA</div>
      <p class="text-slate-400 text-sm max-w-xs font-body">Digitale ervaringen met impact voor Nederlandse ondernemers.</p>
    </div>
    <div class="flex flex-wrap gap-6 font-body text-sm">
      {variant === 'kennismaking' && (
        <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/">Home</a>
      )}
      <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/diensten">Diensten</a>
      <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/projecten">Projecten</a>
      <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/over-ons">Over ons</a>
      {variant === 'kennismaking' ? (
        <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/blog">Blog &amp; artikelen</a>
      ) : (
        <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/blog">Nieuws</a>
      )}
      {variant === 'kennismaking' ? (
        <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/kennismaking">Kennismaking</a>
      ) : (
        <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="/contact">Contact</a>
      )}
    </div>
    <div class="flex gap-6 font-body text-sm font-semibold">
      <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="#">LinkedIn</a>
      <a class="text-slate-400 hover:text-[#7bd345] transition-colors duration-200" href="#">Instagram</a>
    </div>
  </div>
  <div class="border-t border-slate-800">
    <div class="max-w-7xl mx-auto px-8 py-6 flex flex-col md:flex-row justify-between items-center gap-4 font-body text-sm">
      <p class="text-slate-500">© 2024 SASA. All rights reserved.</p>
      <div class="flex gap-6">
        <a class="text-slate-500 hover:text-[#7bd345] transition-colors duration-200" href="#">Privacybeleid</a>
        <a class="text-slate-500 hover:text-[#7bd345] transition-colors duration-200" href="#">Algemene voorwaarden</a>
        <a class="text-slate-500 hover:text-[#7bd345] transition-colors duration-200" href="#">Cookiebeleid</a>
      </div>
    </div>
  </div>
</footer>
