---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Nieuws | SASA">
<main class="max-w-7xl mx-auto px-8 pt-32 pb-20">
<!-- Header & Category Filter -->
<header class="mb-16">
<h1 class="text-5xl md:text-6xl font-extrabold text-on-surface mb-8 tracking-tight px-el" data-depth="0.5">Nieuws</h1>
<div class="flex flex-wrap gap-3" id="category-filters">
<button data-filter="alles" class="filter-btn px-6 py-2 rounded-full bg-primary-container text-on-primary-container font-bold text-sm transition-all shadow-sm active-filter">Alles</button>
<button data-filter="marketing" class="filter-btn px-6 py-2 rounded-full bg-surface-container-low text-on-surface-variant font-semibold text-sm hover:bg-surface-container-high transition-all">Marketing Tips</button>
<button data-filter="strategie" class="filter-btn px-6 py-2 rounded-full bg-surface-container-low text-on-surface-variant font-semibold text-sm hover:bg-surface-container-high transition-all">Bedrijfsstrategie</button>
<button data-filter="groei" class="filter-btn px-6 py-2 rounded-full bg-surface-container-low text-on-surface-variant font-semibold text-sm hover:bg-surface-container-high transition-all">Groei</button>
<button data-filter="design" class="filter-btn px-6 py-2 rounded-full bg-surface-container-low text-on-surface-variant font-semibold text-sm hover:bg-surface-container-high transition-all">Creative Direction</button>
<button data-filter="tech" class="filter-btn px-6 py-2 rounded-full bg-surface-container-low text-on-surface-variant font-semibold text-sm hover:bg-surface-container-high transition-all">Tech Stack</button>
</div>
</header>
<!-- Featured Section -->
<section class="mb-24">
<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
<div class="lg:col-span-7 rounded-3xl overflow-hidden shadow-2xl group relative px-el" data-depth="0.35">
<img alt="Featured artikel" class="w-full h-[500px] object-cover transition-transform duration-700 group-hover:scale-105" src="https://placehold.co/900x500"/>
<div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
</div>
<div class="lg:col-span-5 flex flex-col justify-center px-4 lg:px-8 px-el" data-depth="0.6">
<div class="inline-flex items-center px-3 py-1 rounded-full bg-primary-container/30 text-primary font-bold text-xs uppercase tracking-widest mb-6 w-fit">Nieuws</div>
<h2 class="text-4xl md:text-5xl font-bold mb-6 leading-tight text-on-surface">Digitale excellentie in een AI-gedreven wereld</h2>
<p class="text-on-surface-variant text-lg leading-relaxed mb-8">Ontdek hoe SASA traditionele marketingprocessen hertekent door generatieve AI te combineren met mensgerichte creatieve richting voor een ongekend resultaat.</p>
<div class="flex items-center gap-4 mb-10">
<img alt="Auteur" class="w-12 h-12 rounded-full object-cover border-2 border-primary-container" src="https://placehold.co/48x48"/>
<div>
<p class="font-bold text-on-surface">Sarah Janssen</p>
<p class="text-sm text-on-surface-variant">Directeur Strategie • 8 min lezen</p>
</div>
</div>
<button class="group flex items-center gap-3 text-primary font-bold text-lg hover:gap-5 transition-all">
  Lees meer
  <span class="material-symbols-outlined font-bold">arrow_forward</span>
</button>
</div>
</div>
</section>
<!-- Latest Insights Section -->
<section>
<div class="flex items-center justify-between mb-12">
<h3 class="text-3xl font-bold tracking-tight">Laatste inzichten en trends</h3>
</div>
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
<!-- Card 1 -->
<article class="group cursor-pointer px-el" data-category="marketing" data-depth="0.4">
<div class="relative rounded-xl overflow-hidden mb-6 aspect-[4/3] shadow-lg">
<img alt="Inzicht 1" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://placehold.co/600x450"/>
<div class="absolute top-4 left-4"><span class="bg-white/90 backdrop-blur-md px-3 py-1 rounded-lg text-xs font-bold text-primary uppercase">Nieuws</span></div>
</div>
<p class="text-sm text-on-surface-variant font-medium mb-3">24 mrt 2024 • Marketing</p>
<h4 class="text-xl font-bold leading-snug group-hover:text-primary transition-colors mb-4">De verschuiving naar zero-party data: Waarom privacy-first marketing wint</h4>
</article>
<!-- Card 2 -->
<article class="group cursor-pointer px-el" data-category="strategie" data-depth="0.55">
<div class="relative rounded-xl overflow-hidden mb-6 aspect-[4/3] shadow-lg">
<img alt="Inzicht 2" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://placehold.co/600x450"/>
<div class="absolute top-4 left-4"><span class="bg-white/90 backdrop-blur-md px-3 py-1 rounded-lg text-xs font-bold text-primary uppercase">Nieuws</span></div>
</div>
<p class="text-sm text-on-surface-variant font-medium mb-3">21 mrt 2024 • Strategie</p>
<h4 class="text-xl font-bold leading-snug group-hover:text-primary transition-colors mb-4">Navigeren in de nieuwe normale: hybride werkcultuur bij creatieve bureaus</h4>
</article>
<!-- Card 3 -->
<article class="group cursor-pointer px-el" data-category="tech" data-depth="0.35">
<div class="relative rounded-xl overflow-hidden mb-6 aspect-[4/3] shadow-lg">
<img alt="Inzicht 3" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://placehold.co/600x450"/>
<div class="absolute top-4 left-4"><span class="bg-white/90 backdrop-blur-md px-3 py-1 rounded-lg text-xs font-bold text-primary uppercase">Nieuws</span></div>
</div>
<p class="text-sm text-on-surface-variant font-medium mb-3">18 mrt 2024 • Tech</p>
<h4 class="text-xl font-bold leading-snug group-hover:text-primary transition-colors mb-4">Bouwen voor morgen: Waarom Web3 nog steeds belangrijk is voor merkbetrokkenheid</h4>
</article>
<!-- Card 4 -->
<article class="group cursor-pointer px-el" data-category="design" data-depth="0.5">
<div class="relative rounded-xl overflow-hidden mb-6 aspect-[4/3] shadow-lg">
<img alt="Inzicht 4" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://placehold.co/600x450"/>
<div class="absolute top-4 left-4"><span class="bg-white/90 backdrop-blur-md px-3 py-1 rounded-lg text-xs font-bold text-primary uppercase">Nieuws</span></div>
</div>
<p class="text-sm text-on-surface-variant font-medium mb-3">15 mrt 2024 • Design</p>
<h4 class="text-xl font-bold leading-snug group-hover:text-primary transition-colors mb-4">Visueel storytelling: De 2024 gids voor meeslepende merkidentiteiten</h4>
</article>
<!-- Card 5 -->
<article class="group cursor-pointer px-el" data-category="groei" data-depth="0.45">
<div class="relative rounded-xl overflow-hidden mb-6 aspect-[4/3] shadow-lg">
<img alt="Inzicht 5" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" src="https://placehold.co/600x450"/>
<div class="absolute top-4 left-4"><span class="bg-white/90 backdrop-blur-md px-3 py-1 rounded-lg text-xs font-bold text-primary uppercase">Nieuws</span></div>
</div>
<p class="text-sm text-on-surface-variant font-medium mb-3">12 mrt 2024 • Groei</p>
<h4 class="text-xl font-bold leading-snug group-hover:text-primary transition-colors mb-4">Conversieoptimalisatie: Kleine aanpassingen die enorme resultaten opleveren</h4>
</article>
<!-- Subscribe Card -->
<div class="rounded-xl p-8 flex flex-col justify-between shadow-xl relative overflow-hidden px-el" data-depth="0.4" style="background:#acf67c;">
<div class="absolute -right-12 -top-12 w-48 h-48 opacity-20 blur-3xl rounded-full" style="background:#7ad444;"></div>
<div>
<h4 class="text-2xl font-bold mb-4 text-[#1A2E26]">Blijf voorop lopen</h4>
<p class="mb-8 text-[#1A2E26]/70">Ontvang onze wekelijkse samenvatting van de meest impactvolle trends in digitale strategie en tech.</p>
</div>
<div class="space-y-4">
<input class="w-full px-4 py-3 rounded-lg bg-white border border-[#7bd345]/30 text-on-surface placeholder:text-outline focus:outline-none focus:ring-2 focus:ring-[#7bd345]" placeholder="Jouw e-mailadres" type="email"/>
<button class="w-full py-3 rounded-lg bg-[#1A2E26] text-white font-bold hover:bg-[#2a4034] transition-colors">Nu inschrijven</button>
</div>
</div>
</div>
</section>
<!-- CTA -->
<section class="mt-24 py-16 px-8 rounded-full bg-surface-container-low border border-outline-variant/30 text-center relative overflow-hidden">
<div class="max-w-2xl mx-auto relative z-10">
<h3 class="text-3xl font-bold mb-4">Klaar om jouw project te starten?</h3>
<p class="text-on-surface-variant mb-8 text-lg">Laten we samen iets bijzonders bouwen. Ons team staat klaar om jouw visie te verwezenlijken.</p>
<a href="/contact" class="bg-[#1A2E26] text-white px-10 py-4 rounded-full font-bold text-lg hover:bg-slate-800 transition-all shadow-xl inline-block">Neem contact op</a>
</div>
</section>
</main>

<script>
(function() {
  var filters = document.querySelectorAll('.filter-btn');
  var articles = document.querySelectorAll('[data-category]');
  var activeClass = ['bg-primary-container', 'text-on-primary-container', 'font-bold', 'shadow-sm'];
  var inactiveClass = ['bg-surface-container-low', 'text-on-surface-variant', 'font-semibold', 'hover:bg-surface-container-high'];

  filters.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var filter = btn.getAttribute('data-filter');
      filters.forEach(function(b) {
        activeClass.forEach(function(c) { b.classList.remove(c); });
        inactiveClass.forEach(function(c) { b.classList.add(c); });
      });
      inactiveClass.forEach(function(c) { btn.classList.remove(c); });
      activeClass.forEach(function(c) { btn.classList.add(c); });
      articles.forEach(function(card) {
        if (filter === 'alles' || card.getAttribute('data-category') === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
})();
</script>
</BaseLayout>
