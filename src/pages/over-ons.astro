<script>
/* Horizontale tijdlijn animatie trigger */
(function () {
  var tl = document.querySelector('.tl-wrap');
  if (!tl) return;
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('tl-go');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.2, rootMargin: '0px 0px -60px 0px' });
  io.observe(tl);
})();
</script>

