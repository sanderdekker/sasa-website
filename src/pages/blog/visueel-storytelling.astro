---
import BlogPostLayout from '../../layouts/BlogPostLayout.astro';
---
<BlogPostLayout
  title="Visueel storytelling: De 2024 gids voor meeslepende merkidentiteiten"
  category="Creative Direction"
  date="15 mrt 2024"
  readTime="6 min lezen"
  heroImage="https://placehold.co/1400x640/1A2E26/9fe870?text=SASA"
  authorName="SASA Redactie"
  authorRole="Redactie"
>

  <div class="py-12 flex flex-col items-center gap-4 text-center">
    <div class="w-16 h-16 rounded-2xl flex items-center justify-center" style="background:rgba(159,232,112,0.12);border:1px solid rgba(159,232,112,0.25);">
      <span class="material-symbols-outlined text-primary" style="font-size:32px;">edit_note</span>
    </div>
    <p class="font-headline text-xl font-bold text-on-background">Artikel volgt binnenkort</p>
    <p class="text-on-surface-variant text-sm max-w-xs leading-relaxed">We zijn druk bezig met dit artikel. Kom binnenkort terug voor de volledige inhoud.</p>
  </div>

</BlogPostLayout>
