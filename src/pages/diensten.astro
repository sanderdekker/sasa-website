<!-- Breathing animation for ethereal blobs — only on this page -->
<style is:global>
@keyframes blob-breathe-a {
  0%, 100% { transform: scale(1) translate(0px, 0px); }
  50%       { transform: scale(1.07) translate(10px, -8px); }
}
@keyframes blob-breathe-b {
  0%, 100% { transform: scale(1) translate(0px, 0px); }
  50%       { transform: scale(1.05) translate(-8px, 10px); }
}
@keyframes blob-breathe-c {
  0%, 100% { transform: scale(1) translate(0px, 0px); }
  50%       { transform: scale(1.06) translate(6px, 7px); }
}
#etheral-overlay .etheral-blob:nth-child(1) {
  animation: blob-breathe-a 9s ease-in-out infinite;
  transform-origin: center center;
}
#etheral-overlay .etheral-blob:nth-child(2) {
  animation: blob-breathe-b 12s ease-in-out infinite 1.5s;
  transform-origin: center center;
}
#etheral-overlay .etheral-blob:nth-child(3) {
  animation: blob-breathe-c 15s ease-in-out infinite 3s;
  transform-origin: center center;
}
</style>

<script>
/* Werkwijze graph animation */
(function () {
  var targets = document.querySelectorAll('.ww-wrap, .ww-mob');
  if (!targets.length) return;
  var lp = document.querySelector('.ww-wrap .ww-line');
  if (lp) {
    try {
      var len = Math.ceil(lp.getTotalLength()) + 20;
      lp.style.strokeDasharray = len;
      lp.style.strokeDashoffset = len;
    } catch(e) {}
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('ww-go');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });
  targets.forEach(function (el) { io.observe(el); });
})();
</script>
