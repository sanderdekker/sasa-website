---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Diensten | SASA">
<main class="pt-20">

  <!-- ═══════════════ HERO ═══════════════════════════════ -->
  <section class="relative overflow-hidden py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary-container text-on-secondary-container mb-3 hero-anim hero-anim-1 px-el" data-depth="0.9">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">eco</span>
        <span class="text-xs font-bold tracking-wider uppercase font-label">Websites die resultaat leveren</span>
      </div>
      <h1 class="font-headline text-5xl md:text-6xl font-extrabold text-on-background tracking-tight leading-[1.05] mb-5 hero-anim hero-anim-2 px-el" data-depth="0.5">
        Websites die zorgen voor<br/>
        <span class="text-primary italic">online zichtbaarheid</span><br/>
        <span class="text-on-background">&amp; meer conversie</span>
      </h1>
      <p class="max-w-xl mx-auto text-on-surface-variant text-base leading-relaxed hero-anim hero-anim-3 px-el" data-depth="0.3">
        Wij bouwen op maat gemaakte websites die jouw bedrijf beter vindbaar maken in Google <em>én</em> meer bezoekers omzetten in betalende klanten.
      </p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-3 hero-anim hero-anim-4">
        <a href="/contact" class="btn-primary-gradient text-on-primary px-7 py-3 rounded-2xl font-bold text-base btn-deep-shadow hover:translate-y-[-2px] active:scale-[0.98] transition-transform duration-200 inline-block focus-visible:ring-2 focus-visible:ring-[#7bd345] focus-visible:ring-offset-2">
          Gratis gesprek inplannen
        </a>
        <a href="#waarom-sectie" class="inline-flex items-center gap-2 text-on-surface font-bold text-base hover:text-primary transition-colors duration-200 group">
          Onze aanpak
          <span class="material-symbols-outlined transition-transform duration-200 group-hover:translate-y-1">arrow_downward</span>
        </a>
      </div>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 hero-anim hero-anim-5">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary" style="font-size:15px;font-variation-settings:'FILL' 1;">star</span>
          <span class="text-xs font-semibold text-on-surface-variant">4.9/5 gemiddelde beoordeling</span>
        </div>
        <span class="w-px h-4 bg-outline-variant/50 hidden sm:block"></span>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary" style="font-size:15px;font-variation-settings:'FILL' 1;">check_circle</span>
          <span class="text-xs font-semibold text-on-surface-variant">Gemiddeld 3× meer conversie</span>
        </div>
        <span class="w-px h-4 bg-outline-variant/50 hidden sm:block"></span>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary" style="font-size:15px;font-variation-settings:'FILL' 1;">check_circle</span>
          <span class="text-xs font-semibold text-on-surface-variant">Altijd 100% op maat</span>
        </div>
      </div>
    </div>
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary-fixed/25 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-secondary-fixed/20 rounded-full blur-3xl pointer-events-none"></div>
  </section>

  <!-- ═══════════════ WAAROM ONZE WEBSITES ════════════════ -->
  <section id="waarom-sectie" class="py-28 relative" style="position:relative;z-index:1;">
    <div class="absolute inset-0 pointer-events-none" style="background:rgba(248,250,251,0.45);"></div>
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="grid lg:grid-cols-2 gap-20 items-start">

        <!-- Left: copy + premium feature items -->
        <div class="reveal">
          <span class="text-xs font-bold uppercase tracking-widest text-primary font-label mb-4 block px-el" data-depth="0.4">Onze aanpak</span>
          <h2 class="font-headline text-4xl md:text-5xl font-bold text-on-background mb-8 leading-tight tracking-tight px-el" data-depth="0.5">
            Waarom onze websites<br/><span class="text-primary">écht resultaten leveren.</span>
          </h2>
          <p class="text-on-surface-variant text-lg mb-8 leading-relaxed">Wij bouwen geen pagina's — wij bouwen conversiemachines. Door cutting-edge performance te combineren met intuïtieve UX creëren we digitale ervaringen die bezoekers omzetten in loyale klanten.</p>

          <div class="mb-10">
            <a href="/contact" class="btn-primary-gradient text-on-primary px-8 py-4 rounded-xl font-bold inline-flex items-center gap-2 btn-deep-shadow hover:translate-y-[-2px] active:scale-[0.98] transition-transform duration-200 group">
              Gratis gesprek inplannen
              <span class="material-symbols-outlined transition-transform duration-200 group-hover:translate-x-1">arrow_forward</span>
            </a>
          </div>

          <!-- Premium futuristic feature items -->
          <div class="grid gap-4">

            <div class="group relative flex gap-5 p-5 rounded-2xl cursor-default hover:-translate-y-0.5 transition-transform duration-300"
              style="background:rgba(255,255,255,0.68);border:1px solid rgba(172,246,124,0.22);border-left:2px solid rgba(122,212,68,0.55);backdrop-filter:blur(12px);box-shadow:0 2px 16px rgba(0,0,0,0.04),0 0 28px rgba(159,232,112,0.06);">
              <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity duration-500"
                style="background:radial-gradient(ellipse at 0% 50%,rgba(172,246,124,0.12) 0%,transparent 65%);"></div>
              <div class="w-[50px] h-[50px] shrink-0 rounded-2xl flex items-center justify-center relative z-10"
                style="background:rgba(18,24,16,0.05);border:1px solid rgba(122,212,68,0.32);box-shadow:0 0 18px rgba(122,212,68,0.14);">
                <span class="material-symbols-outlined text-primary" style="font-size:22px;">speed</span>
              </div>
              <div class="relative z-10 flex-1">
                <div class="flex items-center justify-between mb-1">
                  <h4 class="font-headline text-base font-bold text-on-background">Maximale Performance</h4>
                  <span class="font-mono text-xs font-bold px-2 py-0.5 rounded-md" style="color:#5ab52a;background:rgba(122,212,68,0.10);border:1px solid rgba(122,212,68,0.20);">100/100</span>
                </div>
                <p class="text-on-surface-variant text-sm leading-relaxed">Sub-seconde laadtijden die bouncerates laag houden en Google's Core Web Vitals tevreden stellen.</p>
              </div>
            </div>

            <div class="group relative flex gap-5 p-5 rounded-2xl cursor-default hover:-translate-y-0.5 transition-transform duration-300"
              style="background:rgba(255,255,255,0.68);border:1px solid rgba(159,232,112,0.22);border-left:2px solid rgba(122,212,68,0.55);backdrop-filter:blur(12px);box-shadow:0 2px 16px rgba(0,0,0,0.04),0 0 28px rgba(159,232,112,0.06);">
              <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity duration-500"
                style="background:radial-gradient(ellipse at 0% 50%,rgba(159,232,112,0.12) 0%,transparent 65%);"></div>
              <div class="w-[50px] h-[50px] shrink-0 rounded-2xl flex items-center justify-center relative z-10"
                style="background:rgba(18,24,16,0.05);border:1px solid rgba(159,232,112,0.32);box-shadow:0 0 18px rgba(159,232,112,0.14);">
                <span class="material-symbols-outlined text-primary" style="font-size:22px;">touch_app</span>
              </div>
              <div class="relative z-10 flex-1">
                <div class="flex items-center justify-between mb-1">
                  <h4 class="font-headline text-base font-bold text-on-background">Frictionloze UX</h4>
                  <span class="font-mono text-xs font-bold px-2 py-0.5 rounded-md" style="color:#5ab52a;background:rgba(122,212,68,0.10);border:1px solid rgba(122,212,68,0.20);">+3× conversie</span>
                </div>
                <p class="text-on-surface-variant text-sm leading-relaxed">Gebruikersreizen ontworpen rondom psychologie — het pad naar aankoop is moeiteloos.</p>
              </div>
            </div>

            <div class="group relative flex gap-5 p-5 rounded-2xl cursor-default hover:-translate-y-0.5 transition-transform duration-300"
              style="background:rgba(255,255,255,0.68);border:1px solid rgba(122,212,68,0.22);border-left:2px solid rgba(122,212,68,0.55);backdrop-filter:blur(12px);box-shadow:0 2px 16px rgba(0,0,0,0.04),0 0 28px rgba(159,232,112,0.06);">
              <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 pointer-events-none transition-opacity duration-500"
                style="background:radial-gradient(ellipse at 0% 50%,rgba(122,212,68,0.12) 0%,transparent 65%);"></div>
              <div class="w-[50px] h-[50px] shrink-0 rounded-2xl flex items-center justify-center relative z-10"
                style="background:rgba(18,24,16,0.05);border:1px solid rgba(122,212,68,0.32);box-shadow:0 0 18px rgba(122,212,68,0.14);">
                <span class="material-symbols-outlined text-primary" style="font-size:22px;">trending_up</span>
              </div>
              <div class="relative z-10 flex-1">
                <div class="flex items-center justify-between mb-1">
                  <h4 class="font-headline text-base font-bold text-on-background">Hoge Conversieratio</h4>
                  <span class="font-mono text-xs font-bold px-2 py-0.5 rounded-md" style="color:#5ab52a;background:rgba(122,212,68,0.10);border:1px solid rgba(122,212,68,0.20);">98% tevredenheid</span>
                </div>
                <p class="text-on-surface-variant text-sm leading-relaxed">Data-gedreven design dat gebruikers stuurt richting jouw belangrijkste bedrijfsdoelen.</p>
              </div>
            </div>

          </div>
        </div>

        <!-- Right: image + floating badge -->
        <div class="relative reveal px-el" data-depth="0.9" style="transition-delay:0.12s;">
          <div class="aspect-square rounded-[3rem] overflow-hidden" style="box-shadow: 0 32px 64px rgba(0,0,0,0.1), 0 8px 24px rgba(159,232,112,0.15);">
            <img src="/sasa-work-diensten.jpg" alt="SASA team aan het werk" class="w-full h-full object-cover"/>
          </div>
          <div class="absolute -bottom-10 -left-10 bg-white p-8 rounded-[2rem] hidden md:block" style="box-shadow: 0 20px 50px rgba(0,0,0,0.08), 0 4px 16px rgba(159,232,112,0.15);">
            <div class="text-4xl font-black text-primary mb-1 font-headline">99.9%</div>
            <div class="text-sm font-bold text-on-surface-variant uppercase tracking-widest font-label">Uptime Gegarandeerd</div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════ ONZE AANPAK ══════════════════════════ -->
  <section id="werkwijze" class="py-28 relative overflow-hidden" style="position:relative;z-index:1;">

    <div class="absolute inset-0 pointer-events-none" style="background:rgba(248,250,251,0.42);"></div>
    <div class="absolute inset-0 pointer-events-none" style="background-image:radial-gradient(circle, rgba(122,212,68,0.07) 1px, transparent 1px);background-size:28px 28px;opacity:0.7;"></div>

    <div class="max-w-7xl mx-auto px-8 relative z-10">

      <div class="text-center mb-16 reveal">
        <span class="text-xs font-bold uppercase tracking-widest text-primary font-label mb-4 block">Werkwijze</span>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-on-background mb-4 tracking-tight px-el" data-depth="0.5">Onze aanpak in 3 stappen</h2>
        <p class="text-on-surface-variant max-w-xl mx-auto">Van eerste gesprek tot een groeiende digitale aanwezigheid — zo pakken we het aan.</p>
      </div>

      <!-- ── Desktop: SVG ascending graph ─────────── -->
      <div class="hidden md:block ww-wrap" style="position:relative; height:420px;">

        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1000 420"
          preserveAspectRatio="xMidYMid meet" aria-hidden="true" style="overflow:visible;">
          <defs>
            <linearGradient id="wwArea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%"   stop-color="#7ad444" stop-opacity="0.18"/>
              <stop offset="60%"  stop-color="#9fe870" stop-opacity="0.06"/>
              <stop offset="100%" stop-color="#9fe870" stop-opacity="0"/>
            </linearGradient>
            <linearGradient id="wwStroke" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%"   stop-color="#acf67c"/>
              <stop offset="50%"  stop-color="#7ad444"/>
              <stop offset="100%" stop-color="#5ab52a"/>
            </linearGradient>
            <filter id="wwGlow" x="-100%" y="-100%" width="300%" height="300%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="wwLineGlow" x="-5%" y="-100%" width="110%" height="300%">
              <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
          </defs>

          <!-- Grid -->
          <line x1="120" y1="390" x2="920" y2="390" stroke="rgba(0,0,0,0.08)" stroke-width="1"/>
          <line x1="120" y1="290" x2="920" y2="290" stroke="rgba(0,0,0,0.05)" stroke-width="1" stroke-dasharray="5,14"/>
          <line x1="120" y1="190" x2="920" y2="190" stroke="rgba(0,0,0,0.05)" stroke-width="1" stroke-dasharray="5,14"/>
          <line x1="120" y1="90"  x2="920" y2="90"  stroke="rgba(0,0,0,0.05)" stroke-width="1" stroke-dasharray="5,14"/>

          <!-- Y-axis labels -->
          <text x="108" y="390" text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">0</text>
          <text x="108" y="290" text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">33</text>
          <text x="108" y="190" text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">66</text>
          <text x="108" y="90"  text-anchor="end" dominant-baseline="middle" font-family="Manrope" font-size="9" font-weight="600" fill="rgba(65,73,58,0.40)" letter-spacing="1">100</text>
          <text transform="translate(62,240) rotate(-90)" text-anchor="middle" font-family="Manrope" font-size="9" font-weight="700" fill="rgba(65,73,58,0.28)" letter-spacing="3">GROEI %</text>

          <!-- Drop lines -->
          <line x1="190" y1="350" x2="190" y2="390" stroke="rgba(122,212,68,0.35)" stroke-width="1" stroke-dasharray="4,7"/>
          <line x1="500" y1="220" x2="500" y2="390" stroke="rgba(122,212,68,0.25)" stroke-width="1" stroke-dasharray="4,7"/>
          <line x1="810" y1="75"  x2="810" y2="390" stroke="rgba(90,181,42,0.25)"  stroke-width="1" stroke-dasharray="4,7"/>

          <!-- Area fill -->
          <path class="ww-area"
            d="M 190 350 C 320 290 420 255 500 220 C 620 175 710 120 810 75 L 810 390 L 190 390 Z"
            fill="url(#wwArea)"/>

          <!-- Line -->
          <path class="ww-line"
            d="M 190 350 C 320 290 420 255 500 220 C 620 175 710 120 810 75"
            fill="none" stroke="url(#wwStroke)" stroke-width="2.5" stroke-linecap="round"
            filter="url(#wwLineGlow)"/>

          <!-- Node 1: Plan -->
          <circle class="ww-pulse-1" cx="190" cy="350" r="20" fill="none" stroke="#acf67c" stroke-width="1.5" opacity="0"/>
          <circle cx="190" cy="350" r="20" fill="none" stroke="rgba(172,246,124,0.22)" stroke-width="1"/>
          <circle cx="190" cy="350" r="12" fill="white" stroke="#acf67c" stroke-width="2.5" filter="url(#wwGlow)"/>
          <circle cx="190" cy="350" r="4.5" fill="#7ad444"/>
          <text x="190" y="410" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(65,73,58,0.50)" letter-spacing="1">PLAN</text>

          <!-- Node 2: Bouwen -->
          <circle class="ww-pulse-2" cx="500" cy="220" r="20" fill="none" stroke="#9fe870" stroke-width="1.5" opacity="0"/>
          <circle cx="500" cy="220" r="20" fill="none" stroke="rgba(159,232,112,0.22)" stroke-width="1"/>
          <circle cx="500" cy="220" r="12" fill="white" stroke="#9fe870" stroke-width="2.5" filter="url(#wwGlow)"/>
          <circle cx="500" cy="220" r="4.5" fill="#5ab52a"/>
          <text x="500" y="410" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(65,73,58,0.50)" letter-spacing="1">BOUWEN</text>

          <!-- Node 3: Groeien -->
          <circle class="ww-pulse-3" cx="810" cy="75" r="20" fill="none" stroke="#7ad444" stroke-width="1.5" opacity="0"/>
          <circle cx="810" cy="75" r="20" fill="none" stroke="rgba(122,212,68,0.30)" stroke-width="1"/>
          <circle cx="810" cy="75" r="14" fill="white" stroke="#7ad444" stroke-width="3" filter="url(#wwGlow)"/>
          <circle cx="810" cy="75" r="5.5" fill="#5ab52a"/>
          <text x="810" y="48" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(90,181,42,0.70)" letter-spacing="2">↑ GROEI</text>
          <text x="810" y="410" text-anchor="middle" font-family="Plus Jakarta Sans" font-size="10" font-weight="700" fill="rgba(65,73,58,0.50)" letter-spacing="1">GROEIEN</text>

        </svg>

        <!-- Card 1: Plan -->
        <div class="ww-card absolute rounded-2xl p-6 bg-white"
          style="left:0; bottom:36px; width:220px;
                 border:1px solid rgba(172,246,124,0.35);
                 box-shadow:0 4px 24px rgba(0,0,0,0.07),0 0 0 1px rgba(172,246,124,0.10),0 16px 40px rgba(159,232,112,0.12);">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0"
              style="background:rgba(172,246,124,0.18);border:1px solid rgba(172,246,124,0.35);">
              <span class="material-symbols-outlined" style="font-size:18px;color:#5ab52a;">lightbulb</span>
            </div>
            <h3 class="font-headline text-base font-bold text-on-background">Plan</h3>
          </div>
          <p class="text-sm leading-relaxed text-on-surface-variant">
            Diepgaand gesprek over jouw doelen. Roadmap op maat voor jouw succes.
          </p>
        </div>

        <!-- Card 2: Bouwen — positioned below node 2 (node at cy=220, card starts at 250) -->
        <div class="ww-card absolute rounded-2xl p-6 bg-white"
          style="left:50%; transform:translateX(-50%); top:250px; width:220px;
                 border:1px solid rgba(159,232,112,0.35);
                 box-shadow:0 4px 24px rgba(0,0,0,0.07),0 0 0 1px rgba(159,232,112,0.10),0 16px 40px rgba(159,232,112,0.12);">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0"
              style="background:rgba(159,232,112,0.18);border:1px solid rgba(159,232,112,0.35);">
              <span class="material-symbols-outlined" style="font-size:18px;color:#5ab52a;">code</span>
            </div>
            <h3 class="font-headline text-base font-bold text-on-background">Bouwen</h3>
          </div>
          <p class="text-sm leading-relaxed text-on-surface-variant">
            Strakke code en responsief design. Alleen performance, geen ballast.
          </p>
        </div>

        <!-- Card 3: Groeien -->
        <div class="ww-card absolute rounded-2xl p-6 bg-white"
          style="right:0; top:20px; width:220px;
                 border:1px solid rgba(122,212,68,0.40);
                 box-shadow:0 4px 24px rgba(0,0,0,0.07),0 0 0 1px rgba(122,212,68,0.12),0 16px 40px rgba(122,212,68,0.15);">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center shrink-0"
              style="background:rgba(122,212,68,0.18);border:1px solid rgba(122,212,68,0.38);">
              <span class="material-symbols-outlined" style="font-size:18px;color:#5ab52a;">trending_up</span>
            </div>
            <h3 class="font-headline text-base font-bold text-on-background">Groeien</h3>
          </div>
          <p class="text-sm leading-relaxed text-on-surface-variant">
            Continue optimalisatie en data-analyse: jouw website als groeiend ROI-asset.
          </p>
        </div>

      </div><!-- end desktop ww-wrap -->

      <!-- ── Mobile: vertical timeline ─────────── -->
      <div class="flex flex-col md:hidden ww-mob" style="position:relative; padding-left:56px;">

        <div class="ww-vline absolute"
          style="left:21px; top:28px; bottom:28px; width:2px;
                 background:linear-gradient(to bottom, #acf67c 0%, #9fe870 50%, rgba(122,212,68,0.3) 100%);"></div>

        <div class="ww-card relative flex gap-4 p-5 rounded-2xl mb-4 bg-white"
          style="border:1px solid rgba(172,246,124,0.30);box-shadow:0 4px 20px rgba(0,0,0,0.06),0 0 24px rgba(172,246,124,0.10);">
          <div class="absolute rounded-full flex items-center justify-center"
            style="left:-46px;top:50%;transform:translateY(-50%);width:22px;height:22px;
                   background:white;border:2px solid #acf67c;box-shadow:0 0 10px rgba(172,246,124,0.5);">
            <div style="width:7px;height:7px;border-radius:50%;background:#7ad444;"></div>
          </div>
          <div class="w-11 h-11 rounded-xl flex items-center justify-center shrink-0"
            style="background:rgba(172,246,124,0.15);border:1px solid rgba(172,246,124,0.28);">
            <span class="material-symbols-outlined" style="font-size:20px;color:#5ab52a;font-variation-settings:'FILL' 1;">lightbulb</span>
          </div>
          <div>
            <div class="flex items-baseline gap-2 mb-1">
              <span class="font-mono text-xs font-black text-primary">01</span>
              <h3 class="font-headline text-base font-bold text-on-background">Plan</h3>
            </div>
            <p class="text-sm leading-relaxed text-on-surface-variant">Diepgaand gesprek over jouw doelen. We bouwen een roadmap op maat.</p>
          </div>
        </div>

        <div class="ww-card relative flex gap-4 p-5 rounded-2xl mb-4 bg-white"
