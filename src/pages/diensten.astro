---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Diensten | SASA">
<main class="pt-20">

  <!-- ═══════════════ HERO ═══════════════════════════════ -->
  <section class="relative overflow-hidden bg-mesh py-32 lg:py-44">
    <div class="max-w-7xl mx-auto px-8 relative z-10 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-secondary-container text-on-secondary-container mb-6 hero-anim hero-anim-1 px-el" data-depth="0.9">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'FILL' 1;">eco</span>
        <span class="text-xs font-bold tracking-wider uppercase font-label">Resultaatgerichte Dienstverlening</span>
      </div>
      <h1 class="font-headline text-6xl md:text-8xl font-extrabold text-on-background tracking-tight leading-[1.0] mb-8 hero-anim hero-anim-2 px-el" data-depth="0.5">
        High-Performance<br/>
        <span class="text-primary">Digital Foundations</span>
      </h1>
      <p class="max-w-2xl mx-auto text-on-surface-variant text-lg md:text-xl leading-relaxed hero-anim hero-anim-3 px-el" data-depth="0.3">
        Wij bouwen razendsnel, op maat gemaakte websites die jouw conversies maximaliseren. Persoonlijk, ambitieus en altijd gericht op groei.
      </p>
    </div>
    <div class="absolute -top-24 -left-24 w-96 h-96 bg-primary-fixed/25 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-secondary-fixed/20 rounded-full blur-3xl pointer-events-none"></div>
  </section>

  <!-- ═══════════════ PRICING ════════════════════════════ -->
  <section class="py-28 bg-white relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-8 relative z-10">
      <div class="text-center mb-20 reveal">
        <span class="text-xs font-bold uppercase tracking-widest text-primary font-label mb-4 block">Investering</span>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-on-background mb-4 tracking-tight">Transparante prijzen</h2>
        <p class="text-on-surface-variant max-w-md mx-auto">Eenvoudige, waardegedreven pakketten voor ondernemers in elke fase.</p>
      </div>
      <div class="grid lg:grid-cols-3 gap-8 items-start">
        <!-- Core -->
        <div class="bg-white p-10 rounded-[2rem] pricing-shadow border border-slate-100 flex flex-col transition-transform hover:-translate-y-1 duration-300 reveal px-el" data-depth="0.4">
          <div class="mb-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-primary font-bold">bolt</span>
              <h3 class="font-headline text-2xl font-bold text-on-background">Core</h3>
            </div>
            <p class="text-on-surface-variant text-sm mb-6">Alle essentiële tools die je nodig hebt voor een professionele online aanwezigheid.</p>
            <div class="flex items-baseline">
              <span class="text-4xl font-extrabold text-on-background tracking-tight">€2.450</span>
              <span class="text-on-surface-variant text-sm ml-2">/project</span>
            </div>
          </div>
          <div class="mb-8">
            <button class="w-full py-4 rounded-full border-2 border-outline-variant font-bold text-on-surface hover:bg-surface-container-low transition-colors duration-200">Kies Core</button>
          </div>
          <div class="border-t border-slate-100 pt-8">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-6 font-label">Core inclusief:</p>
            <ul class="space-y-4 flex-grow">
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">sync_alt</span><span class="text-on-surface-variant text-sm">5 pagina's op maat ontworpen</span></li>
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">desktop_windows</span><span class="text-on-surface-variant text-sm">SEO-fundament</span></li>
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">phone_iphone</span><span class="text-on-surface-variant text-sm">Volledig responsief design</span></li>
            </ul>
          </div>
        </div>
        <!-- Advanced (Featured) -->
        <div class="pricing-featured p-10 rounded-[2rem] pricing-shadow border-2 border-primary/40 flex flex-col relative transition-transform hover:-translate-y-1 duration-300 lg:scale-105 z-10 reveal px-el" data-depth="0.65">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-primary text-on-primary px-6 py-1.5 rounded-full text-xs font-black tracking-widest uppercase" style="box-shadow: 0 4px 16px rgba(159,232,112,0.4);">Meest Gekozen</div>
          <div class="mb-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-primary font-bold">local_fire_department</span>
              <h3 class="font-headline text-2xl font-bold text-on-background">Advanced</h3>
            </div>
            <p class="text-on-surface-variant text-sm mb-6">Voor groeiende ondernemers die maximale prestaties en een opvallende online aanwezigheid willen.</p>
            <div class="flex items-baseline">
              <span class="text-4xl font-extrabold text-on-background tracking-tight">€4.950</span>
              <span class="text-on-surface-variant text-sm ml-2">/project</span>
            </div>
          </div>
          <div class="mb-8">
            <button class="w-full py-4 rounded-full bg-on-background text-white font-bold text-lg hover:opacity-90 transition-opacity duration-200 flex items-center justify-center gap-2" style="box-shadow: 0 8px 20px rgba(0,0,0,0.15);">
              Neem contact op
              <span class="material-symbols-outlined text-sm">chat_bubble</span>
            </button>
          </div>
          <div class="border-t border-primary/20 pt-8">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-6 font-label">Alles in Core, plus:</p>
            <ul class="space-y-4 flex-grow">
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">bar_chart</span><span class="text-on-surface-variant text-sm">Geavanceerd animatiepakket</span></li>
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">shopping_cart</span><span class="text-on-surface-variant text-sm">E-commerce integratie</span></li>
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">cloud</span><span class="text-on-surface-variant text-sm">1 jaar premium hosting</span></li>
            </ul>
          </div>
        </div>
        <!-- Enterprise -->
        <div class="bg-white p-10 rounded-[2rem] pricing-shadow border border-slate-100 flex flex-col transition-transform hover:-translate-y-1 duration-300 reveal px-el" data-depth="0.35">
          <div class="mb-8">
            <div class="flex items-center gap-2 mb-4">
              <span class="material-symbols-outlined text-primary font-bold">business</span>
              <h3 class="font-headline text-2xl font-bold text-on-background">Enterprise</h3>
            </div>
            <p class="text-on-surface-variant text-sm mb-6">Complexe platformen en maatwerk webapplicaties voor grootschalige operaties.</p>
            <div class="flex items-baseline">
              <span class="text-4xl font-extrabold text-on-background tracking-tight">Op maat</span>
            </div>
          </div>
          <div class="mb-8">
            <button class="w-full py-4 rounded-full border-2 border-outline-variant font-bold text-on-surface hover:bg-surface-container-low transition-colors duration-200">Vraag een offerte aan</button>
          </div>
          <div class="border-t border-slate-100 pt-8">
            <p class="text-xs font-bold uppercase tracking-widest text-on-surface-variant mb-6 font-label">Enterprise features:</p>
            <ul class="space-y-4 flex-grow">
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">architecture</span><span class="text-on-surface-variant text-sm">Maatwerk SaaS-architectuur</span></li>
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">brush</span><span class="text-on-surface-variant text-sm">Volledig brand identity design</span></li>
              <li class="flex items-start gap-3"><span class="material-symbols-outlined text-primary text-xl mt-0.5">person_pin</span><span class="text-on-surface-variant text-sm">Dedicated projectmanager</span></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ WHY IT WORKS ══════════════════════ -->
  <section class="py-28 bg-surface-container-low">
    <div class="max-w-7xl mx-auto px-8">
      <div class="grid lg:grid-cols-2 gap-20 items-center">
        <div class="reveal">
          <span class="text-xs font-bold uppercase tracking-widest text-primary font-label mb-4 block px-el" data-depth="0.4">Onze aanpak</span>
          <h2 class="font-headline text-4xl md:text-5xl font-bold text-on-background mb-8 leading-tight tracking-tight px-el" data-depth="0.5">
            Waarom onze websites<br/><span class="text-primary">écht resultaten leveren.</span>
          </h2>
          <p class="text-on-surface-variant text-lg mb-12 leading-relaxed">Wij bouwen geen pagina's; wij bouwen conversiemachines. Door cutting-edge performance te combineren met intuïtieve UX, creëren we digitale ervaringen die bezoekers omzetten in loyale klanten.</p>
          <div class="grid gap-8">
            <div class="flex gap-6">
              <div class="w-14 h-14 shrink-0 bg-white rounded-2xl flex items-center justify-center" style="box-shadow: 0 4px 16px rgba(159,232,112,0.2), 0 2px 8px rgba(0,0,0,0.06);">
                <span class="material-symbols-outlined text-primary text-3xl">speed</span>
              </div>
              <div>
                <h4 class="font-headline text-xl font-bold mb-2 text-on-background">Maximale Performance</h4>
                <p class="text-on-surface-variant leading-relaxed">Sub-seconde laadtijden die bouncerates laag houden en Google's Core Web Vitals tevreden stellen.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="w-14 h-14 shrink-0 bg-white rounded-2xl flex items-center justify-center" style="box-shadow: 0 4px 16px rgba(159,232,112,0.2), 0 2px 8px rgba(0,0,0,0.06);">
                <span class="material-symbols-outlined text-primary text-3xl">touch_app</span>
              </div>
              <div>
                <h4 class="font-headline text-xl font-bold mb-2 text-on-background">Frictionloze UX</h4>
                <p class="text-on-surface-variant leading-relaxed">Gebruikersreizen ontworpen rondom psychologie — het pad naar aankoop is moeiteloos.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="w-14 h-14 shrink-0 bg-white rounded-2xl flex items-center justify-center" style="box-shadow: 0 4px 16px rgba(159,232,112,0.2), 0 2px 8px rgba(0,0,0,0.06);">
                <span class="material-symbols-outlined text-primary text-3xl">trending_up</span>
              </div>
              <div>
                <h4 class="font-headline text-xl font-bold mb-2 text-on-background">Hoge Conversieratio</h4>
                <p class="text-on-surface-variant leading-relaxed">Data-gedreven design dat gebruikers stuurt richting jouw belangrijkste bedrijfsdoelen.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative reveal px-el" data-depth="0.9">
          <div class="aspect-square rounded-[3rem] overflow-hidden" style="box-shadow: 0 32px 64px rgba(0,0,0,0.1), 0 8px 24px rgba(159,232,112,0.15);">
            <img src="/sasa-work-diensten.jpg" alt="SASA team aan het werk" class="w-full h-full object-cover"/>
          </div>
          <div class="absolute -bottom-10 -left-10 bg-white p-8 rounded-[2rem] hidden md:block" style="box-shadow: 0 20px 50px rgba(0,0,0,0.08), 0 4px 16px rgba(159,232,112,0.15);">
            <div class="text-4xl font-black text-primary mb-1 font-headline">99.9%</div>
            <div class="text-sm font-bold text-on-surface-variant uppercase tracking-widest font-label">Uptime Gegarandeerd</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PROCESS ════════════════════════════ -->
  <section class="py-28 bg-white">
    <div class="max-w-7xl mx-auto px-8">
      <div class="text-center mb-20 reveal">
        <span class="text-xs font-bold uppercase tracking-widest text-primary font-label mb-4 block">Werkwijze</span>
        <h2 class="font-headline text-4xl md:text-5xl font-bold text-on-background mb-4 tracking-tight px-el" data-depth="0.5">Onze aanpak in 3 stappen</h2>
        <p class="text-on-surface-variant max-w-xl mx-auto">Van eerste gesprek tot een groeiende digitale aanwezigheid — zo pakken we het aan.</p>
      </div>
      <div class="hidden md:block relative reveal" style="height:440px;">
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 1000 380" preserveAspectRatio="none" aria-hidden="true" style="overflow:visible;">
          <defs>
            <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#9fe870" stop-opacity="0.5"/>
              <stop offset="100%" stop-color="#9fe870" stop-opacity="0"/>
            </linearGradient>
          </defs>
          <line x1="0" y1="360" x2="1000" y2="360" stroke="#e8ede4" stroke-width="1"/>
          <line x1="0" y1="260" x2="1000" y2="260" stroke="#e8ede4" stroke-width="1" stroke-dasharray="6,10"/>
          <line x1="0" y1="160" x2="1000" y2="160" stroke="#e8ede4" stroke-width="1" stroke-dasharray="6,10"/>
          <path d="M 160 330 Q 380 270 500 210 Q 660 140 840 70 L 840 360 L 160 360 Z" fill="url(#areaGrad)" opacity="0.18"/>
          <path d="M 160 330 Q 380 270 500 210 Q 660 140 840 70" fill="none" stroke="#9fe870" stroke-width="3" stroke-linecap="round" style="filter:drop-shadow(0 4px 8px rgba(159,232,112,0.5));"/>
          <circle cx="160" cy="330" r="11" fill="#acf67c" stroke="white" stroke-width="3" style="filter:drop-shadow(0 4px 12px rgba(172,246,124,0.6));"/>
          <text x="160" y="334" text-anchor="middle" dominant-baseline="middle" font-family="Plus Jakarta Sans" font-weight="800" font-size="10" fill="#092100">01</text>
          <circle cx="500" cy="210" r="11" fill="#9fe870" stroke="white" stroke-width="3" style="filter:drop-shadow(0 4px 12px rgba(159,232,112,0.6));"/>
          <text x="500" y="214" text-anchor="middle" dominant-baseline="middle" font-family="Plus Jakarta Sans" font-weight="800" font-size="10" fill="#092100">02</text>
          <circle cx="840" cy="70" r="13" fill="#7ad444" stroke="white" stroke-width="3" style="filter:drop-shadow(0 6px 16px rgba(122,212,68,0.7));"/>
          <text x="840" y="74" text-anchor="middle" dominant-baseline="middle" font-family="Plus Jakarta Sans" font-weight="800" font-size="10" fill="white">03</text>
          <text x="870" y="52" font-family="Plus Jakarta Sans" font-weight="700" font-size="11" fill="#7ad444" opacity="0.7">↑ Groei</text>
        </svg>
        <div class="absolute bg-white rounded-2xl p-6 shadow-md border border-outline-variant/20" style="left:0;bottom:32px;width:240px;">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-primary-fixed rounded-xl flex items-center justify-center shrink-0" style="box-shadow:0 4px 16px rgba(172,246,124,0.4);">
              <span class="material-symbols-outlined text-on-primary text-xl">lightbulb</span>
            </div>
            <h3 class="font-headline text-lg font-bold text-on-background">Plan</h3>
          </div>
          <p class="text-on-surface-variant text-sm leading-relaxed">Diepgaand gesprek over jouw doelen en groeiwensen. Roadmap op maat voor jouw succes.</p>
        </div>
        <div class="absolute bg-white rounded-2xl p-6 shadow-md border border-outline-variant/20" style="left:50%;transform:translateX(-50%);top:220px;width:240px;">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shrink-0" style="box-shadow:0 4px 16px rgba(159,232,112,0.4);">
              <span class="material-symbols-outlined text-on-primary text-xl">code</span>
            </div>
            <h3 class="font-headline text-lg font-bold text-on-background">Bouwen</h3>
          </div>
          <p class="text-on-surface-variant text-sm leading-relaxed">Jouw visie in strak code en responsief design. Alleen performance, geen ballast.</p>
        </div>
        <div class="absolute bg-white rounded-2xl p-6 shadow-md border border-[#9fe870]/30" style="right:0;top:40px;width:240px;">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 bg-secondary-fixed rounded-xl flex items-center justify-center shrink-0" style="box-shadow:0 4px 16px rgba(208,232,220,0.6);">
              <span class="material-symbols-outlined text-secondary text-xl">trending_up</span>
            </div>
            <h3 class="font-headline text-lg font-bold text-on-background">Groeien</h3>
          </div>
          <p class="text-on-surface-variant text-sm leading-relaxed">Continue optimalisatie en data-analyse zodat jouw website een groeiend ROI-asset blijft.</p>
        </div>
      </div>
      <!-- Mobile fallback -->
      <div class="flex flex-col gap-6 md:hidden">
        <div class="bg-surface-container-low p-8 rounded-2xl border border-outline-variant/20">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-primary-fixed rounded-xl flex items-center justify-center shrink-0" style="box-shadow:0 4px 16px rgba(172,246,124,0.4);">
              <span class="material-symbols-outlined text-on-primary text-2xl">lightbulb</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-background">01. Plan</h3>
          </div>
          <p class="text-on-surface-variant leading-relaxed">Diepgaand gesprek over jouw doelen en groeiwensen. We bouwen een roadmap op maat.</p>
        </div>
        <div class="bg-surface-container-low p-8 rounded-2xl border border-outline-variant/20">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-primary rounded-xl flex items-center justify-center shrink-0" style="box-shadow:0 4px 16px rgba(159,232,112,0.4);">
              <span class="material-symbols-outlined text-on-primary text-2xl">code</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-background">02. Bouwen</h3>
          </div>
          <p class="text-on-surface-variant leading-relaxed">Jouw visie in strak code en responsief design. Geen overbodige ballast — alleen performance.</p>
        </div>
        <div class="bg-surface-container-low p-8 rounded-2xl border border-outline-variant/20">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-12 h-12 bg-secondary-fixed rounded-xl flex items-center justify-center shrink-0" style="box-shadow:0 4px 16px rgba(208,232,220,0.6);">
              <span class="material-symbols-outlined text-secondary text-2xl">trending_up</span>
            </div>
            <h3 class="font-headline text-xl font-bold text-on-background">03. Groeien</h3>
          </div>
          <p class="text-on-surface-variant leading-relaxed">Continue optimalisatie via data-analyse zodat jouw website een groeiend ROI-asset blijft.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA ════════════════════════════════ -->
  <section class="py-24 bg-mesh border-t border-surface-container">
    <div class="max-w-4xl mx-auto px-8 text-center reveal">
      <h2 class="font-headline text-4xl md:text-5xl font-bold mb-6 tracking-tight text-on-background px-el" data-depth="0.4">Klaar om te starten?</h2>
      <p class="text-on-surface-variant text-lg mb-12 max-w-xl mx-auto">We nemen momenteel nieuwe projecten aan. Reserveer jouw plek en laten we samen iets bouwen dat groeit.</p>
      <div class="flex flex-wrap justify-center gap-8 mb-12">
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">verified</span>
          <span class="font-bold text-on-surface font-label">Google Cloud Partner</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">bolt</span>
          <span class="font-bold text-on-surface font-label">Core Web Vitals Ready</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="material-symbols-outlined text-primary">eco</span>
          <span class="font-bold text-on-surface font-label">100% Green Hosting</span>
        </div>
      </div>
      <a href="/contact" class="btn-primary-gradient text-on-primary px-12 py-5 rounded-2xl font-bold text-lg btn-deep-shadow hover:translate-y-[-2px] active:scale-[0.98] transition-transform duration-200 inline-block">
        Start een gesprek
      </a>
    </div>
  </section>

</main>
</BaseLayout>
